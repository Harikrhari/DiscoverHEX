rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.admin == true;
    }

    function isServiceAccount() {
      // Cloud Functions service account has admin custom claim set via Admin SDK
      return isAuthenticated() &&
        request.auth.token.firebase.sign_in_provider == 'google.com' &&
        request.auth.token.serviceAccount == true;
    }

    function isFunctionOrAdmin() {
      return isAdmin() || isServiceAccount();
    }

    function validString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }

    function validPositiveNumber(val) {
      return val is number && val > 0;
    }

    // ─── Users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['email', 'createdAt']) &&
        validString(request.resource.data.email, 5, 320);
      allow update: if isOwner(userId) &&
        // Prevent users from escalating their own role
        !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAdmin();

      // User's private subcollections
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      match /paymentMethods/{pmId} {
        allow read: if isOwner(userId);
        allow write: if false; // Only written by Cloud Functions
      }
    }

    // ─── Products ─────────────────────────────────────────────────────────────

    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create: if isAdmin() &&
        request.resource.data.keys().hasAll(['title', 'price', 'category', 'createdAt']) &&
        validString(request.resource.data.title, 1, 200) &&
        validPositiveNumber(request.resource.data.price);
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /variants/{variantId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() &&
          request.resource.data.userId == request.auth.uid &&
          validString(request.resource.data.comment, 1, 2000) &&
          request.resource.data.rating is number &&
          request.resource.data.rating >= 1 &&
          request.resource.data.rating <= 5;
        allow update, delete: if isAdmin();
      }
    }

    // ─── Orders ───────────────────────────────────────────────────────────────

    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.items.size() > 0 &&
        validPositiveNumber(request.resource.data.total);
      allow update: if isAdmin() ||
        // Cloud Functions can update any order field
        isFunctionOrAdmin();
      allow delete: if isAdmin();

      match /events/{eventId} {
        allow read: if isAuthenticated() &&
          (get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid || isAdmin());
        allow write: if isFunctionOrAdmin();
      }
    }

    // ─── Charity Funds ────────────────────────────────────────────────────────

    match /charityFunds/{campaignId} {
      allow read: if true; // Public transparency
      allow write: if isFunctionOrAdmin(); // Only functions and admins write

      match /transactions/{txId} {
        allow read: if true;
        allow write: if isFunctionOrAdmin();
      }
    }

    // ─── Sponsors ─────────────────────────────────────────────────────────────

    match /sponsors/{sponsorId} {
      allow read: if true;
      allow create: if isAdmin() &&
        request.resource.data.keys().hasAll(['name', 'tier', 'contactEmail', 'createdAt']);
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /analytics/{docId} {
        allow read: if isAdmin() ||
          (isAuthenticated() && resource.data.sponsorId == sponsorId);
        allow write: if isFunctionOrAdmin();
      }

      match /impressions/{impressionId} {
        allow read: if isAdmin();
        allow write: if isFunctionOrAdmin();
      }
    }

    // ─── Creators ─────────────────────────────────────────────────────────────

    match /creators/{creatorId} {
      // Public profile fields visible to all; private fields gated
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.auth.uid == creatorId &&
        request.resource.data.keys().hasAll(['displayName', 'email', 'createdAt']);
      allow update: if (isAuthenticated() && request.auth.uid == creatorId &&
        // Creators cannot modify their commission rate or payout info
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['commissionRate', 'payoutAccountId', 'totalEarnings'])) ||
        isAdmin();
      allow delete: if isAdmin();

      match /commissions/{commissionId} {
        allow read: if isAuthenticated() && request.auth.uid == creatorId || isAdmin();
        allow write: if isFunctionOrAdmin();
      }

      match /payouts/{payoutId} {
        allow read: if isAuthenticated() && request.auth.uid == creatorId || isAdmin();
        allow write: if isFunctionOrAdmin();
      }
    }

    // ─── Campaigns (Marketing) ────────────────────────────────────────────────

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if isAdmin() &&
        request.resource.data.keys().hasAll(['name', 'startDate', 'endDate', 'status']);
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /metrics/{metricId} {
        allow read: if isAdmin();
        allow write: if isFunctionOrAdmin();
      }
    }

    // ─── Social Posts ─────────────────────────────────────────────────────────

    match /socialPosts/{postId} {
      allow read: if isAdmin();
      allow write: if isFunctionOrAdmin();
    }

    // ─── Tax Cache ────────────────────────────────────────────────────────────

    match /taxCache/{cacheId} {
      allow read: if isAuthenticated();
      allow write: if isFunctionOrAdmin();
    }

    // ─── App Config (non-sensitive) ───────────────────────────────────────────

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Catch-all: deny everything else ─────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
