# DiscoverHEX Mobile App - Environment Variables
# Copy this file to .env and fill in real values
# All variables must be prefixed with EXPO_PUBLIC_ to be accessible in the app

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Stripe Configuration
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
EXPO_PUBLIC_STRIPE_MERCHANT_ID=merchant.com.discoverhex.app

# App Configuration
EXPO_PUBLIC_API_BASE_URL=https://api.discoverhex.com
EXPO_PUBLIC_APP_ENV=development

# Charity Configuration
EXPO_PUBLIC_CHARITY_PERCENT=5
EXPO_PUBLIC_MONTHLY_GOAL=50000
